# Example .env (sanitized) — DO NOT commit real secrets
# Copy to `.env` and fill in real values locally.

# App / CORS
PORT=4000
ALLOWED_ORIGIN=https://YOUR-DOMAIN.com

# Supabase (backend only)
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Retell
RETELL_API_KEY=YOUR_RETELL_API_KEY
RETELL_FROM_NUMBER=+491234567890
RETELL_AGENT_BEAUTY=agent_xxx
RETELL_TENANT_AGENT_MAP={}
RETELL_TENANT_HISTORY_AGENT_MAP={}
AUTH_EMAIL_BINDINGS={}
RETELL_WEBHOOK_SECRET=

# SMTP / notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=info@example.com
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM="Tawano <info@example.com>"
CONTACT_RECEIVER=info@example.com

# Optional integrations
SEVEN_API_KEY=YOUR_SEVEN_API_KEY
SMS_FROM=InfoSMS
SMS_AFTER_CALL_TEMPLATE=Vielen Dank fuer Ihr Gespraech mit {booking_link}
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=

# Retell tool endpoints
RETELL_TOOL_SECRET=

# Booking link used by send_booking_link when no booking_link is passed
BOOKING_LINK_URL=https://www.example.com

# Webhook endpoints
SMS_WEBHOOK_URL=
CALLBACK_WEBHOOK_URL=
